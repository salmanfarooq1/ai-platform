# .env.example — Template for all environment variables
# Copy to .env.local, .env.demo, or .env.prod and fill in real values.
# NEVER commit real credentials. This file is safe to commit.

# Deployment mode: "local", "demo", or "prod"
MODE=local

# ---- LLM ----
# Override model selection (optional — defaults are set per MODE in config.py)
# LLM_MODEL=ollama/llama3
# EMBED_MODEL=ollama/nomic-embed-text

# Azure OpenAI (prod mode only)
# AZURE_OAI_BASE=https://your-resource.openai.azure.com/
# AZURE_OAI_KEY=your-key-here

# Groq (demo mode only)
# GROQ_API_KEY=gsk_your-key-here

# ---- Database ----
# Override the full connection string (optional — defaults are set per MODE in config.py)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aiplatform

# ---- Redis ----
# REDIS_URL=redis://localhost:6379

# ---- Embeddings ----
# Override embedding dimension (default: 768, standardized across all modes)
# EMBEDDING_DIM=768
